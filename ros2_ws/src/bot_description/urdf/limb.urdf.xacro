<?xml version="1.0" encoding="utf-8"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="limb">
    <!-- Joint limits loaded from YAML -->
    <xacro:property name="limits"
                    value="${xacro.load_yaml('$(find bot_description)/config/joint_limits.yaml')}"/>

    <!-- Internal limb geometry + internal joints (hfe/kfe). -->
    <xacro:macro name="_limb_core" params="prefix mult">
        <!-- Links -->
        <link name="${prefix}shoulder_link">
            <inertial>
                <origin xyz="0.018766 0.016329 0.0079907" rpy="0 0 0"/>
                <mass value="0.01481"/>
                <inertia ixx="1.3996E-06" ixy="-1.6833E-08" ixz="-7.906E-10" iyy="1.8819E-06" iyz="-3.0123E-10"
                         izz="2.5913E-06"/>
            </inertial>
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="package://bot_description/meshes/haa_horn.STL" scale="1 1 1"/>
                </geometry>
            </visual>
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="package://bot_description/meshes/shoulder_casing.STL" scale="1 1 1"/>
                </geometry>
            </visual>
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="package://bot_description/meshes/hfe_servo.STL" scale="1 1 1"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="package://bot_description/meshes/haa_horn.STL" scale="1 1 1"/>
                </geometry>
            </collision>
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="package://bot_description/meshes/shoulder_casing.STL" scale="1 1 1"/>
                </geometry>
            </collision>
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="package://bot_description/meshes/hfe_servo.STL" scale="1 1 1"/>
                </geometry>
            </collision>
        </link>
        <link name="${prefix}femur_link">
            <inertial>
                <origin xyz="0.012387 -0.00071898 0.017314" rpy="0 0 0"/>
                <mass value="0.015915"/>
                <inertia ixx="9.3139E-07" ixy="-7.9194E-10" ixz="-9.4792E-08" iyy="3.7356E-06" iyz="1.3143E-09"
                         izz="3.3585E-06"/>
            </inertial>
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="package://bot_description/meshes/hfe_horn.STL" scale="1 1 1"/>
                </geometry>
            </visual>
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="package://bot_description/meshes/femur.STL" scale="1 1 1"/>
                </geometry>
            </visual>
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="package://bot_description/meshes/kfe_servo.STL" scale="1 1 1"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="package://bot_description/meshes/hfe_horn.STL" scale="1 1 1"/>
                </geometry>
            </collision>
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="package://bot_description/meshes/femur.STL" scale="1 1 1"/>
                </geometry>
            </collision>
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="package://bot_description/meshes/kfe_servo.STL" scale="1 1 1"/>
                </geometry>
            </collision>
        </link>
        <link name="${prefix}tibia_link">
            <inertial>
                <origin xyz="0.0019117 0.036934 -0.0058072" rpy="0 0 0"/>
                <mass value="0.052333"/>
                <inertia ixx="3.6178E-05" ixy="3.873E-06" ixz="-6.0786E-07" iyy="2.0314E-05" iyz="6.2224E-06"
                         izz="2.4513E-05"/>
            </inertial>
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="package://bot_description/meshes/tibia.STL" scale="1 1 1"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="package://bot_description/meshes/tibia.STL" scale="1 1 1"/>
                </geometry>
            </collision>
        </link>

        <joint name="${prefix}hfe_joint" type="revolute">
            <origin xyz="0.02088 0 0.0165" rpy="1.5708 ${0.0 if mult > 0 else 3.1416} 1.5708"/>
            <parent link="${prefix}shoulder_link"/>
            <child link="${prefix}femur_link"/>
            <axis xyz="0 0 ${mult * 1}"/>
            <limit lower="${limits['hfe']['lower']}"
                   upper="${limits['hfe']['upper']}"
                   effort="${limits['hfe']['effort']}"
                   velocity="${limits['hfe']['velocity']}"/>
        </joint>

        <joint name="${prefix}kfe_joint" type="revolute">
            <origin xyz="0.046 0 0.0106" rpy="0 0 0"/>
            <parent link="${prefix}femur_link"/>
            <child link="${prefix}tibia_link"/>
            <axis xyz="0 0 ${mult * -1}"/>
            <limit lower="${limits['kfe']['lower']}"
                   upper="${limits['kfe']['upper']}"
                   effort="${limits['kfe']['effort']}"
                   velocity="${limits['kfe']['velocity']}"/>
        </joint>
    </xacro:macro>

    <!-- Public limb macro: owns full attachment to body, hiding internal limb construction. -->
    <xacro:macro name="limb" params="prefix x y z r p yw mult parent_link:=body_link">
        <xacro:_limb_core prefix="${prefix}_" mult="${mult}"/>
        <joint name="${prefix}_haa_joint" type="revolute">
            <parent link="${parent_link}"/>
            <child link="${prefix}_shoulder_link"/>
            <origin xyz="${x} ${y} ${z}" rpy="${r} ${p} ${yw}"/>
            <axis xyz="0 0 ${mult * -1}"/>
            <limit lower="${limits['haa']['lower']}"
                   upper="${limits['haa']['upper']}"
                   effort="${limits['haa']['effort']}"
                   velocity="${limits['haa']['velocity']}"/>
        </joint>
    </xacro:macro>
</robot>
